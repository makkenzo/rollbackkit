{
    "name": "@rollbackkit/demo-next",
    "version": "0.0.0",
    "private": true,
    "description": "Demo application for RollbackKit.",
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "typecheck": "tsc --noEmit",
        "lint": "biome check .",
        "test": "vitest run",
        "test:unit": "vitest run test/unit",
        "test:integration": "vitest run test/integration",
        "predb:migrate": "pnpm --filter @rollbackkit/postgres build",
        "db:migrate": "node scripts/migrate-demo-db.mjs",
        "predb:seed": "pnpm --filter @rollbackkit/postgres build",
        "db:seed": "node scripts/seed-demo-db.mjs",
        "predb:reset": "pnpm --filter @rollbackkit/postgres build",
        "db:reset": "node scripts/reset-demo-db.mjs",
        "clean": "rm -rf .next"
    },
    "dependencies": {
        "@rollbackkit/core": "workspace:*",
        "@rollbackkit/postgres": "workspace:*",
        "next": "catalog:",
        "pg": "catalog:",
        "react": "catalog:",
        "react-dom": "catalog:",
        "server-only": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@types/pg": "catalog:",
        "@types/react": "catalog:",
        "@types/react-dom": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
